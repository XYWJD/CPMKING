<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:"PingFang SC","Microsoft YaHei",sans-serif}
body{background:#0a0a0a;color:#00f0d0;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:15px}
.container{background:#0f1419;width:100%;max-width:420px;padding:30px 20px;border-radius:20px;box-shadow:0 0 30px rgba(0,240,208,0.15);border:1px solid rgba(0,240,208,0.2);position:relative}
.container::before{content:"";position:absolute;top:60px;left:20px;right:20px;height:2px;background:linear-gradient(90deg,transparent,#00f0d0,transparent)}
.title{text-align:center;font-size:32px;font-weight:900;margin-bottom:30px;color:#00f0d0;letter-spacing:2px;text-shadow:0 0 8px rgba(0,240,208,0.6)}
.author{text-align:center;font-size:12px;color:#00a090;margin-bottom:30px;line-height:1.4;opacity:.8}
.page{display:none;animation:fadeIn .3s ease forwards}
.page.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.input-box{margin-bottom:20px}
.input-box label{display:block;margin-bottom:8px;font-size:14px;color:#00f0d0;font-weight:500}
.input-box input{width:100%;padding:14px 16px;background:#121a20;border:1px solid rgba(0,240,208,0.3);border-radius:16px;color:#00f0d0;outline:none;font-size:15px;transition:.2s}
.input-box input:focus{border-color:#00f0d0;box-shadow:0 0 10px rgba(0,240,208,0.2)}
.btn{width:100%;padding:15px;background:#00f0d0;border:none;border-radius:16px;color:#0a0a0a;font-weight:bold;font-size:15px;margin-top:10px;cursor:pointer;transition:.2s;box-shadow:0 0 12px rgba(0,240,208,0.3)}
.btn:hover{background:#00d0b0;transform:translateY(-1px);box-shadow:0 0 16px rgba(0,240,208,0.5)}
.btn-gray{background:#121a20;color:#00f0d0;border:1px solid rgba(0,240,208,0.3);box-shadow:none}
.btn-gray:hover{background:#162028;border-color:#00f0d0}
.btn-small{padding:8px 12px;font-size:12px;margin-top:0}
.func{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:25px}
.func button{padding:12px;background:#121a20;border:1px solid rgba(0,240,208,0.3);border-radius:14px;color:#00f0d0;font-size:14px;cursor:pointer;transition:.2s;position:relative;overflow:hidden}
.func button::after{content:"";position:absolute;bottom:0;left:0;right:0;height:1px;background:repeating-linear-gradient(90deg,#00f0d0,#00f0d0 4px,transparent 4px,transparent 8px);opacity:.5}
.func button:hover{background:#00f0d0;color:#0a0a0a;border-color:#00f0d0}
.funcContent{animation:fadeIn .25s ease}
.log-box{margin-top:25px;padding:15px;background:#121a20;border-radius:14px;min-height:80px;font-size:14px;line-height:1.5;border:1px solid rgba(0,240,208,0.2);position:relative}
.log-box::after{content:"";position:absolute;top:0;left:0;right:0;bottom:0;border:1px dashed rgba(0,240,208,0.15);border-radius:14px;pointer-events:none}
.card-item{padding:10px;background:#121a20;border:1px solid rgba(0,240,208,0.2);border-radius:10px;margin-bottom:8px;font-size:13px;display:flex;justify-content:space-between;align-items:center}
.card-used{color:#ff4060}
.card-expired{color:#ffaa00}
.card-valid{color:#00f0a0}
.success{color:#00f0a0;font-weight:500}
.error{color:#ff4060;font-weight:500}
.info{color:#00f0d0;font-weight:500}
